{
  "openapi": "3.1.0",
  "info": {
    "title": "Shop AI Staff Backend API",
    "description": "GitHub から clone / download 後すぐに起動できる、Android フロント接続用のモック API です。",
    "version": "1.0.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/": {
      "get": {
        "summary": "Root",
        "operationId": "root__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/chat": {
      "post": {
        "summary": "Chat",
        "operationId": "chat_api_v1_chat_post",
        "parameters": [
          {
            "name": "X-Device-ID",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Device-Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/staff-call": {
      "post": {
        "summary": "Staff Call",
        "operationId": "staff_call_api_v1_staff_call_post",
        "parameters": [
          {
            "name": "X-Device-ID",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-Device-Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StaffCallRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StaffCallResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiMessage": {
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "system",
              "user",
              "assistant"
            ],
            "title": "Role"
          },
          "content": {
            "type": "string",
            "title": "Content"
          }
        },
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "title": "ApiMessage"
      },
      "ChatChoice": {
        "properties": {
          "message": {
            "$ref": "#/components/schemas/ApiMessage"
          },
          "finish_reason": {
            "type": "string",
            "enum": [
              "stop",
              "length",
              "content_filter"
            ],
            "title": "Finish Reason",
            "default": "stop"
          }
        },
        "type": "object",
        "required": [
          "message"
        ],
        "title": "ChatChoice"
      },
      "ChatRequest": {
        "properties": {
          "messages": {
            "items": {
              "$ref": "#/components/schemas/ApiMessage"
            },
            "type": "array",
            "title": "Messages"
          },
          "model": {
            "type": "string",
            "title": "Model",
            "default": "shopai-auto"
          },
          "stream": {
            "type": "boolean",
            "title": "Stream",
            "default": false
          },
          "device_id": {
            "type": "string",
            "maxLength": 128,
            "minLength": 1,
            "title": "Device Id"
          },
          "location_id": {
            "type": "string",
            "maxLength": 128,
            "minLength": 1,
            "title": "Location Id"
          },
          "language_code": {
            "type": "string",
            "maxLength": 16,
            "minLength": 2,
            "title": "Language Code"
          },
          "session_id": {
            "type": "string",
            "maxLength": 128,
            "minLength": 1,
            "title": "Session Id"
          },
          "is_new_session": {
            "type": "boolean",
            "title": "Is New Session",
            "default": false
          },
          "is_staff_call": {
            "type": "boolean",
            "title": "Is Staff Call",
            "default": false
          },
          "question_level": {
            "type": "string",
            "enum": [
              "EASY",
              "MEDIUM",
              "HARD"
            ],
            "title": "Question Level",
            "default": "EASY"
          },
          "timestamp": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Timestamp"
          },
          "metadata": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Metadata"
          }
        },
        "type": "object",
        "required": [
          "messages",
          "device_id",
          "location_id",
          "language_code",
          "session_id",
          "timestamp"
        ],
        "title": "ChatRequest"
      },
      "ChatResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "default": ""
          },
          "choices": {
            "items": {
              "$ref": "#/components/schemas/ChatChoice"
            },
            "type": "array",
            "title": "Choices"
          },
          "model_used": {
            "type": "string",
            "title": "Model Used",
            "default": ""
          },
          "session_id": {
            "type": "string",
            "title": "Session Id",
            "default": ""
          },
          "requires_staff": {
            "type": "boolean",
            "title": "Requires Staff",
            "default": false
          },
          "answer_source": {
            "type": "string",
            "enum": [
              "structured",
              "rag",
              "fast_llm",
              "deep_llm",
              "safe_fallback"
            ],
            "title": "Answer Source",
            "default": "structured"
          },
          "confidence": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Confidence"
          },
          "handoff_reason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Handoff Reason"
          }
        },
        "type": "object",
        "title": "ChatResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "service": {
            "type": "string",
            "title": "Service"
          }
        },
        "type": "object",
        "required": [
          "status",
          "service"
        ],
        "title": "HealthResponse"
      },
      "StaffCallRequest": {
        "properties": {
          "reason": {
            "type": "string",
            "maxLength": 512,
            "minLength": 1,
            "title": "Reason"
          },
          "device_id": {
            "type": "string",
            "maxLength": 128,
            "minLength": 1,
            "title": "Device Id"
          },
          "location_id": {
            "type": "string",
            "maxLength": 128,
            "minLength": 1,
            "title": "Location Id"
          },
          "timestamp": {
            "type": "integer",
            "minimum": 0.0,
            "title": "Timestamp"
          },
          "trigger_text": {
            "type": "string",
            "maxLength": 2000,
            "title": "Trigger Text",
            "default": ""
          },
          "session_id": {
            "type": "string",
            "maxLength": 128,
            "title": "Session Id",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "reason",
          "device_id",
          "location_id",
          "timestamp"
        ],
        "title": "StaffCallRequest"
      },
      "StaffCallResponse": {
        "properties": {
          "accepted": {
            "type": "boolean",
            "title": "Accepted"
          },
          "message": {
            "type": "string",
            "title": "Message",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "accepted"
        ],
        "title": "StaffCallResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
