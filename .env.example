APP_NAME=Shop AI Staff Backend API
APP_VERSION=1.0.0
HOST=0.0.0.0
PORT=8080
ALLOWED_ORIGINS=*

# PostgreSQL
POSTGRES_DSN=postgresql+asyncpg://shopai:shopai@localhost:5432/shopai

# Fast LLM Node (RTX 5080)
LOCAL_FAST_LLM_BASE_URL=http://gpu-node:8000/v1
LOCAL_FAST_LLM_MODEL=fast-local-model

# Deep LLM Node (mac mini)
LOCAL_DEEP_LLM_BASE_URL=http://mac-mini:11434/v1
LOCAL_DEEP_LLM_MODEL=deep-local-model
